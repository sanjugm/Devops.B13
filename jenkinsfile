pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo "Cloning repo..."
                checkout scm
            }
        }

        stage('Compile') {
            steps {
                echo "Compiling..."
                sh 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                echo "Testing..."
                sh 'mvn test'
            }
        }

        stage('Package') {
            steps {
                echo "Packaging..."
                sh 'mvn package'
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploying to Tomcat..."
                sh '''
                cp target/*.war /opt/tomcat/webapps/
                '''
            }
        }
    }

    post {
        success {
            echo 'SUCCESS 🚀'
        }
        failure {
            echo 'FAILED ❌'
        }
    }
}
